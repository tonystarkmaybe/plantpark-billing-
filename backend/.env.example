# ─────────────────────────────────────────────────────────────────────────────
# Plantora backend environment configuration.
# Copy this file to `.env` and fill in real values. NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────────────────────

# Privileged role connection. OWNS the schema and runs Alembic migrations.
# This role creates/alters tables. It is NOT used by the running API.
DATABASE_URL_ADMIN=postgresql+psycopg://plantora_admin:CHANGE_ME_ADMIN@localhost:5432/plantora

# Limited application role connection used by the FastAPI runtime.
# This role MUST be NOSUPERUSER and NOBYPASSRLS so Row Level Security is enforced.
DATABASE_URL_APP=postgresql+psycopg://plantora_app:CHANGE_ME_APP@localhost:5432/plantora

# JSON Web Token signing. Use a long random secret (e.g. `openssl rand -hex 32`).
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
# 720 minutes = 12 hours. Shop owners stay logged in for a working day.
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Bootstrap admin (the platform owner). Used once by scripts/create_admin.py.
BOOTSTRAP_ADMIN_EMAIL=owner@plantora.app
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_BOOTSTRAP_ADMIN_PASSWORD

# Comma-separated list of allowed CORS origins (frontend dev servers).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Media / image storage.
# MEDIA_ROOT: where uploaded product images are stored. Relative to backend/ in
#   dev (./media); set an absolute path on the VPS (e.g. /var/lib/plantora/media).
# MEDIA_URL_PREFIX: URL prefix images are served at. Locally FastAPI serves this;
#   on the VPS, point Nginx at MEDIA_ROOT for this prefix instead.
MEDIA_ROOT=./media
MEDIA_URL_PREFIX=/media

# Name of the limited Postgres app role. The initial migration GRANTs table
# privileges to this role. Must match the user in DATABASE_URL_APP.
APP_DB_ROLE=plantora_app

# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp delivery (prompt 10A/B)
# ─────────────────────────────────────────────────────────────────────────────
# Global kill switch. When false, sends ALWAYS degrade to a wa.me click-to-chat
# link (zero infrastructure, no ban risk). Leave false until OpenWA is set up.
WHATSAPP_ENABLED=false

# OpenWA (self-hosted gateway) REST API base — include the /api path.
# Local dev example: http://localhost:2785/api  · VPS: internal docker address.
OPENWA_BASE_URL=http://localhost:2785/api
# X-API-Key sent on every OpenWA request.
OPENWA_API_KEY=CHANGE_ME_OPENWA_API_KEY
# Per-request timeout (seconds) for OpenWA HTTP calls.
OPENWA_TIMEOUT_SECONDS=8

# "openwa" → try the shop's OpenWA session, fall back to wa.me on any problem.
# "wa_me"  → force the wa.me link path only (never call the gateway).
WHATSAPP_DEFAULT_BACKEND=openwa

# Default country code for normalizing bare national numbers (India = 91).
WHATSAPP_COUNTRY_CODE=91
